<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- World anchor — the arm is bolted to the floor here -->
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- BASE: The heavy platform the arm sits on -->
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.0700" length="0.0600"/></geometry>
      <origin xyz="0 0 0.0300" rpy="0 0 0"/>
      <material name="col0"><color rgba="0.15 0.15 0.15 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0700" length="0.0600"/></geometry>
      <origin xyz="0 0 0.0300" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.0300"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- JOINT 1: Spins the whole arm left/right (like turning at the waist) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.0600" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="150" velocity="2.5"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <link name="link_1">
    <visual>
      <geometry><cylinder radius="0.0400" length="0.3000"/></geometry>
      <origin xyz="0 0 0.1500" rpy="0 0 0"/>
      <material name="col1"><color rgba="0.20 0.40 0.90 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0400" length="0.3000"/></geometry>
      <origin xyz="0 0 0.1500" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.1500"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- JOINT 2: Shoulder — tilts the upper arm forward/backward -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.3000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="120" velocity="2.0"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <link name="link_2">
    <visual>
      <geometry><cylinder radius="0.0360" length="0.2500"/></geometry>
      <origin xyz="0 0 0.1250" rpy="0 0 0"/>
      <material name="col2"><color rgba="0.10 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0360" length="0.2500"/></geometry>
      <origin xyz="0 0 0.1250" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.1250"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 3: Elbow — bends the forearm -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.2500" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="0.0" effort="100" velocity="2.0"/>
    <dynamics damping="0.7" friction="0.1"/>
  </joint>
  <link name="link_3">
    <visual>
      <geometry><cylinder radius="0.0320" length="0.2000"/></geometry>
      <origin xyz="0 0 0.1000" rpy="0 0 0"/>
      <material name="col3"><color rgba="0.20 0.75 0.30 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0320" length="0.2000"/></geometry>
      <origin xyz="0 0 0.1000" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0 0 0.1000"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 4: Forearm roll — rotates the forearm (like unscrewing a lid) -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.2000" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="80" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="link_4">
    <visual>
      <geometry><cylinder radius="0.0280" length="0.1500"/></geometry>
      <origin xyz="0 0 0.0750" rpy="0 0 0"/>
      <material name="col4"><color rgba="0.90 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0280" length="0.1500"/></geometry>
      <origin xyz="0 0 0.0750" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.0750"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 5: Wrist pitch — tilts the hand up/down -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.1500" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="60" velocity="3.0"/>
    <dynamics damping="0.4" friction="0.05"/>
  </joint>
  <link name="link_5">
    <visual>
      <geometry><cylinder radius="0.0240" length="0.1000"/></geometry>
      <origin xyz="0 0 0.0500" rpy="0 0 0"/>
      <material name="col5"><color rgba="0.70 0.15 0.85 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0240" length="0.1000"/></geometry>
      <origin xyz="0 0 0.0500" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.0500"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- JOINT 6: Wrist roll — rotates the gripper -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.1000" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="40" velocity="4.0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>
  <link name="link_6">
    <visual>
      <geometry><box size="0.0560 0.0560 0.0500"/></geometry>
      <origin xyz="0 0 0.0250" rpy="0 0 0"/>
      <material name="col6"><color rgba="0.90 0.20 0.20 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.0560 0.0560 0.0500"/></geometry>
      <origin xyz="0 0 0.0250" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0.0250"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- END EFFECTOR: The white ball at the very tip of the arm (the "hand") -->
  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link_6"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.0500" rpy="0 0 0"/>
  </joint>
  <link name="ee_link">
    <visual>
      <geometry><sphere radius="0.0180"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

</robot>
